rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth & Role Helpers using Secure Custom Claims
    function signedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return signedIn() && (request.auth.token.role == 'admin' || request.auth.token.admin == true);
    }
    
    function isVendor() {
      return signedIn() && (request.auth.token.role == 'vendor' || request.auth.token.vendor == true);
    }
    
    function isDriver() {
      return signedIn() && (request.auth.token.role == 'driver' || request.auth.token.driver == true);
    }

    function isVendorOfStore(storeId) {
      return signedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.vendorId == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    // 1. users Collection (Protect role, points, and referrals from client updates)
    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId 
                    && (!('role' in request.resource.data) || request.resource.data.role == 'customer')
                    && (!('points' in request.resource.data) || request.resource.data.points == 0);
      allow read: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'points', 'referralCode', 'referredBy', 'createdAt'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. stores Collection (Disable client-side updates of totalOrders and pricing/fee zones)
    match /stores/{storeId} {
      allow read: if true;
      allow create: if isAdmin() || (isVendor() && request.resource.data.vendorId == request.auth.uid);
      allow update: if isAdmin() || (isVendor() && resource.data.vendorId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalOrders', 'vendorId', 'createdAt']));
      allow delete: if isAdmin();
    }

    // 3. products Collection (Strictly prevent price modifications by customers or anonymous users)
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || (isVendor() && isVendorOfStore(request.resource.data.storeId));
      allow update: if isAdmin() || (isVendor() && isVendorOfStore(resource.data.storeId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['storeId', 'createdAt', 'currentStock', 'reservedStock', 'averageRating', 'ratingsCount']));
      allow delete: if isAdmin() || (isVendor() && isVendorOfStore(resource.data.storeId));
    }

    // 4. categories Collection
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. banners Collection
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. orders & orderGroups Collections (Zero client-side order creation/status update)
    match /orders/{orderId} {
      allow read: if isAdmin()
                  || (signedIn() && resource.data.customerId == request.auth.uid)
                  || (signedIn() && isVendorOfStore(resource.data.shopId))
                  || (isDriver() && resource.data.driverId == request.auth.uid);
      // Client cannot create orders directly. Must call Cloud Function.
      allow create: if false;
      // Client can only update reviews/ratings on their orders. Other updates must use Cloud Functions.
      allow update: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingStore', 'ratingDriver', 'ratingProducts', 'ratingComment']));
      allow delete: if isAdmin();
    }

    match /orderGroups/{groupId} {
      allow read: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 7. chatThreads Collection (Secure chat between parties)
    match /chatThreads/{threadId} {
      allow read, write: if signedIn();
      
      match /messages/{messageId} {
        allow read, create: if signedIn();
        allow update, delete: if isAdmin();
      }
    }

    // 8. notifications Collection
    match /notifications/{notifId} {
      allow create: if isAdmin() || signedIn();
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // 9. reviews Collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 10. drivers Collection
    match /drivers/{driverId} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == driverId;
      allow update: if isAdmin() || (signedIn() && isOwner(driverId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isApproved', 'createdAt']));
      allow delete: if isAdmin();
    }
    
    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if isOwner(driverId) || isAdmin();
    }
    
    match /driverLocationHistory/{driverId}/points/{pointId} {
      allow read: if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId);
      allow update, delete: if isAdmin();
    }

    match /driverMetrics/{metricId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 11. Wallets & Financial Transactions (Cloud Function/Admin ONLY write)
    match /walletTransactions/{transId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid) || (isVendor() && resource.data.storeId == getUserData().storeId);
      allow write: if isAdmin();
    }

    match /walletSettlements/{settleId} {
      allow read: if signedIn();
      allow create: if isVendor() && request.resource.data.storeId == getUserData().storeId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 12. Returns & Refunds
    match /returnRequests/{reqId} {
      allow create: if signedIn() && request.resource.data.customerId == request.auth.uid;
      allow read: if isAdmin() || resource.data.customerId == request.auth.uid || isVendorOfStore(resource.data.storeId);
      allow update: if isAdmin() || (isVendor() && isVendorOfStore(resource.data.storeId));
      allow delete: if isAdmin();
    }
    match /refundRequests/{reqId} {
      allow create: if signedIn() && request.resource.data.customerId == request.auth.uid;
      allow read: if isAdmin() || resource.data.customerId == request.auth.uid || isVendorOfStore(resource.data.storeId);
      allow update: if isAdmin() || (isVendor() && isVendorOfStore(resource.data.storeId));
      allow delete: if isAdmin();
    }
    match /replacementRequests/{reqId} {
      allow create: if signedIn() && request.resource.data.customerId == request.auth.uid;
      allow read: if isAdmin() || resource.data.customerId == request.auth.uid || isVendorOfStore(resource.data.storeId);
      allow update: if isAdmin() || (isVendor() && isVendorOfStore(resource.data.storeId));
      allow delete: if isAdmin();
    }

    // 13. coupons Collection (Read-only for clients, updates locked to Admin/Server)
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 14. campaigns Collection
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 15. deliveryZones Collection
    match /deliveryZones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 16. businessHours Collection
    match /businessHours/{hoursId} {
      allow read: if true;
      allow create: if isAdmin() || (isVendor() && isVendorOfStore(request.resource.data.storeId));
      allow update: if isAdmin() || (isVendor() && isVendorOfStore(resource.data.storeId));
      allow delete: if isAdmin();
    }

    // 17. invoices Collection
    match /invoices/{invoiceId} {
      allow read: if isAdmin() 
                  || (signedIn() && resource.data.customerId == request.auth.uid)
                  || (signedIn() && isVendorOfStore(resource.data.storeId));
      allow write: if isAdmin();
    }

    // 18. platformMetrics Collection
    match /platformMetrics/{metricId} {
      allow read, write: if isAdmin();
    }

    // 19. productTemplates Collection
    match /productTemplates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 20. assets Collection
    match /assets/{assetId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isAdmin() || resource.data.ownerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // 21. stockMovements (Only vendor/admin can write, customer can only read stock statuses)
    match /stockMovements/{movementId} {
      allow read: if signedIn();
      allow write: if isAdmin() || isVendor();
    }

    // 22. config & settings
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /adminSettings/{document=**} {
      allow read, write: if isAdmin();
    }
    match /platformSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 23. analytics & brands
    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 24. Vendor Catalog Settings
    match /vendorCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isVendor() && request.resource.data.storeId == getUserData().storeId;
    }
    match /vendorSubCategories/{subCatId} {
      allow read: if true;
      allow write: if isAdmin() || (isVendor() && request.resource.data.storeId == getUserData().storeId);
    }
    match /vendorBrands/{brandId} {
      allow read: if true;
      allow write: if isAdmin() || (isVendor() && request.resource.data.storeId == getUserData().storeId);
    }
    match /offers/{offerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || (isVendor() && request.resource.data.storeId == getUserData().storeId);
    }
    
    // 25. driverRequests Collection
    match /driverRequests/{requestId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 26. referrals Collection
    match /referrals/{referralId} {
      allow read: if isAdmin() || (signedIn() && (resource.data.referrerId == request.auth.uid || resource.data.referredId == request.auth.uid));
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 27. pointsHistory Collection
    match /pointsHistory/{historyId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin(); // Server-only creation
      allow update, delete: if isAdmin();
    }

    // 28. carts Collection
    match /carts/{cartId} {
      allow read, write: if signedIn() && request.auth.uid == cartId;
    }

    // 29. securityLogs & Immutable Ledger
    match /securityLogs/{logId} {
      allow read, write: if isAdmin();
    }
    match /platformTransactions/{txId} {
      allow read, write: if isAdmin();
    }
    match /vendorTransactions/{txId} {
      allow read: if isAdmin() || (isVendor() && resource.data.vendorId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /driverTransactions/{txId} {
      allow read: if isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /settlementRequests/{reqId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // 30. payments, refunds, and logs
    match /payments/{paymentId} {
      allow read: if signedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /refundRequests/{refundId} {
      allow read: if signedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /paymentLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /vendorWallets/{walletId} {
      allow read: if isAdmin() || (isVendor() && walletId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /driverWallets/{walletId} {
      allow read: if isAdmin() || (isDriver() && walletId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    // 31. system Collection (Counters & App Version)
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
